# ===== 园圈平台 环境配置 =====
# 复制此文件为 .env 并修改配置

# 应用
NODE_ENV=development
PORT=3001
BRAND_NAME=园圈
OPERATOR_NAME=宏创
CORS_ORIGIN=*

# 数据库
DB_HOST=localhost
DB_PORT=5432
DB_NAME=circle
DB_USER=circle
DB_PASSWORD=circle_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=circle-dev-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# AI (可选，不配置则使用规则引擎)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
